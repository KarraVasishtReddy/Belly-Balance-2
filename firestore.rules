rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn(); } 
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() <= 120 &&
             data.photoURL is string && data.photoURL.size() <= 600 &&
             data.activeMode in ['balanced', 'dieting', 'digestion'];
    }

    function isValidLog(data) {
      return data.userId == request.auth.uid &&
             data.id is string && data.id.size() <= 64 &&
             data.foodId is string && data.foodId.size() <= 64 &&
             data.portion in ['palm', 'fist', 'handful', 'thumb'] &&
             data.score is number && data.score >= -1000 && data.score <= 5000 &&
             data.timestamp is number;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && userId == request.auth.uid;
      allow create: if isSignedIn() && userId == request.auth.uid && 
                       incoming().keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'createdAt', 'activeMode']) &&
                       incoming().keys().size() == 6 &&
                       incoming().createdAt == request.time &&
                       isValidUser(incoming());
      allow update: if isSignedIn() && userId == request.auth.uid && 
                       incoming().uid == existing().uid &&
                       incoming().email == existing().email &&
                       incoming().createdAt == existing().createdAt &&
                       isValidUser(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'activeMode']);

      match /logs/{logId} {
        allow list, get: if isSignedIn() && userId == request.auth.uid;
        allow create: if isSignedIn() && userId == request.auth.uid && 
                         logId == incoming().id &&
                         incoming().keys().hasAll(['id', 'foodId', 'portion', 'timestamp', 'score', 'userId']) &&
                         incoming().keys().size() == 6 &&
                         isValidLog(incoming()) &&
                         exists(/databases/$(database)/documents/users/$(userId));
        allow delete: if isSignedIn() && userId == request.auth.uid;
      }
    }
  }
}
