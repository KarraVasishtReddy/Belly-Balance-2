{
  "entities": {
    "user": {
      "title": "User",
      "description": "User profile document",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "log": {
      "title": "Log Entry",
      "description": "Individual food logging entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "foodId": { "type": "string" },
        "portion": { "type": "string", "enum": ["palm", "fist", "handful", "thumb"] },
        "timestamp": { "type": "string", "format": "number" },
        "score": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["id", "foodId", "portion", "timestamp", "score", "userId"]
    }
  },
  "firestore": {
    "users/{userId}": { "schema": "user", "description": "Global user record" },
    "users/{userId}/logs/{logId}": { "schema": "log", "description": "Users individual antioxidant logs" }
  }
}
